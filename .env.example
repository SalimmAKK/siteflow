# Firebase config for the NEW SiteFlow Firebase project (not your old Operion one).
# Get these from: Firebase Console -> Project settings -> General -> Your apps -> SDK setup and config
# Copy this file to .env and fill in the values. Never commit the real .env file.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web3Forms — used for the marketing site's Contact form (src/lib/web3forms.ts)
# and for team invitation emails (src/pages/Team.tsx). EmailJS has been dropped.
# Get this from: https://web3forms.com -> create a form -> Access Key
VITE_WEB3FORMS_KEY=
